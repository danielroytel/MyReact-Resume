---
import BaseLayout from '@components/layout/BaseLayout.astro';
import Bookmark from '@components/icons/Bookmark.astro';
import { getCollection } from 'astro:content';
import { kebabCase } from '@utils';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter(p => !p.data.draft);

  const tagMap = new Map<string, typeof posts>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      const key = kebabCase(tag);
      if (!tagMap.has(key)) tagMap.set(key, []);
      tagMap.get(key)!.push(post);
    }
  }

  return [...tagMap.entries()].map(([tag, taggedPosts]) => ({
    params: { tag },
    props: {
      // Preserve the original (non-kebabed) tag name from the first match
      tagName: taggedPosts[0].data.tags.find(t => kebabCase(t) === tag) ?? tag,
      posts: taggedPosts.toSorted((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { tagName, posts } = Astro.props;
---

<BaseLayout title={`${tagName} - Pensieve`}>
  <main class="main">
    <header>
      <h1 class="big-heading">#{tagName}</h1>
      <p class="subtitle">
        <a href="/pensieve/tags">All tags</a>
      </p>
    </header>

    <ul class="grid">
      {
        posts.map(post => {
          const { title, description, slug, date, tags } = post.data;
          const formattedDate = new Date(date).toLocaleDateString();
          const href = slug.startsWith('/') ? slug : `/pensieve/${slug}`;
          return (
            <li class="post" data-sr>
              <div class="post__inner">
                <header>
                  <div class="post__icon"><Bookmark /></div>
                  <h5 class="post__title"><a href={href}>{title}</a></h5>
                  <p class="post__desc">{description}</p>
                </header>
                <footer>
                  <span class="post__date">{formattedDate}</span>
                  <ul class="post__tags">
                    {tags.map(tag => (
                      <li>
                        <a href={`/pensieve/tags/${kebabCase(tag)}/`} class="inline-link">#{tag}</a>
                      </li>
                    ))}
                  </ul>
                </footer>
              </div>
            </li>
          );
        })
      }
    </ul>
  </main>
</BaseLayout>

<style>
  .main > header {
    margin-bottom: 100px;
    text-align: center;
  }

  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    grid-gap: 15px;
    margin-top: 50px;
    position: relative;
  }
  @media (max-width: 1080px) {
    .grid { grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); }
  }

  .post {
    transition: var(--transition);
    cursor: default;
  }
  @media (prefers-reduced-motion: no-preference) {
    .post:hover .post__inner,
    .post:focus-within .post__inner {
      transform: translateY(-7px);
    }
  }
  .post a {
    position: relative;
    z-index: 1;
  }

  .post__inner {
    box-shadow: 0 10px 30px -15px var(--navy-shadow);
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    position: relative;
    height: 100%;
    padding: 2rem 1.75rem;
    border-radius: var(--border-radius);
    background-color: var(--light-navy);
  }
  .post__inner header,
  .post__inner header a {
    width: 100%;
  }

  .post__icon {
    display: flex;
    align-items: center;
    color: var(--orange);
    margin-bottom: 30px;
    margin-left: -5px;
  }
  .post__icon svg {
    width: 40px;
    height: 40px;
  }

  .post__title {
    margin: 0 0 10px;
    color: var(--lightest-slate);
    font-size: var(--fz-xxl);
  }
  .post__title a {
    position: static;
  }
  .post__title a::before {
    content: '';
    display: block;
    position: absolute;
    z-index: 0;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
  }

  .post__desc {
    color: var(--light-slate);
    font-size: 17px;
  }

  .post__date {
    color: var(--light-slate);
    font-family: var(--font-mono);
    font-size: var(--fz-xxs);
    text-transform: uppercase;
  }

  .post__tags {
    display: flex;
    align-items: flex-end;
    flex-wrap: wrap;
    padding: 0;
    margin: 0;
    list-style: none;
  }
  .post__tags li {
    color: var(--orange);
    font-family: var(--font-mono);
    font-size: var(--fz-xxs);
    line-height: 1.75;
  }
  .post__tags li:not(:last-of-type) {
    margin-right: 15px;
  }
</style>
